# ============================================================
#  IBM watsonx.ai — Library AI Agent Environment Variables
# ============================================================

# IBM Cloud API Key (generate from https://cloud.ibm.com/iam/apikeys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM watsonx.ai Project ID (from your watsonx.ai project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai URL (region-specific)
# US Dallas  : https://us-south.ml.cloud.ibm.com
# EU Frankfurt: https://eu-de.ml.cloud.ibm.com
# UK London  : https://eu-gb.ml.cloud.ibm.com
# Tokyo      : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
FLASK_PORT=5000
FLASK_DEBUG=True

# Application Settings
APP_NAME=Library AI Agent
INSTITUTION_NAME=University Central Library
MAX_RECOMMENDATIONS=8
SESSION_LIFETIME_HOURS=24
